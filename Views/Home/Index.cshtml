@model FacilitiesSensor.Models.DashboardViewModel@model FacilitiesSensor.Models.DashboardViewModel

@{
Layout = "~/Views/Shared/_Layout.cshtml";
ViewData["Title"] = "Dashboard Facilities";
}

<div class="container mt-4">


    <div class="row">

        <!-- TANQUE A -->
        <div class="col-md-6">

            <div class="card shadow-sm">

                <div class="card-header text-center fw-bold">
                    Tanque A
                </div>

                <div class="card-body text-center">

                    <div class="tank">

                        <div class="tank-mask">

                            <div class="water"
                                 style="height:@Model.Tanques[0].NivelActual%">
                            </div>

                        </div>

                        <img src="/images/copitank22.png"
                             alt="Tanque A" />


                        <div class="line linea-20">20%</div>
                        <div class="line linea-40">40%</div>
                        <div class="line linea-60">60%</div>
                        <div class="line linea-80">80%</div>
                        <div class="line linea-100">100%</div>

                    </div>

                    <h5 class="mt-3">
                        Nivel actual: @Model.Tanques[0].NivelActual%
                    </h5>

                    <span class="badge bg-success">
                        Operando
                    </span>

                </div>

            </div>

        </div>

        <!-- TANQUE B -->
        <div class="col-md-6">

            <div class="card shadow-sm">

                <div class="card-header text-center fw-bold">
                    Tanque B
                </div>

                <div class="card-body text-center">

                    <div class="tank">

                        <div class="tank-mask">

                            <div class="water"
                                 style="height:@Model.Tanques[1].NivelActual%">
                            </div>

                        </div>

                        <img src="/images/copitank22.png"
                             alt="Tanque B" />


                        <div class="line linea-20">20%</div>
                        <div class="line linea-40">40%</div>
                        <div class="line linea-60">60%</div>
                        <div class="line linea-80">80%</div>
                        <div class="line linea-100">100%</div>

                    </div>

                    <h5 class="mt-3">
                        Nivel actual: @Model.Tanques[1].NivelActual%
                    </h5>

                    <span class="badge bg-warning text-dark">
                        Atención
                    </span>

                </div>

            </div>

        </div>

    </div>

    <!-- SENSORES -->

    <div class="row mt-5">

        <div class="col-12">
            <h3 class="mb-4">
                Sensores de Planta
            </h3>
        </div>

        <div class="col-md-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h6>Temperatura</h6>

                    <h2>25°C</h2>

                    <small class="text-muted">
                        Actualizado hace 1 min
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h6>Presión</h6>

                    <h2>3.5 Bar</h2>

                    <small class="text-muted">
                        Actualizado hace 1 min
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h6>Flujo</h6>

                    <h2>120 L/min</h2>

                    <small class="text-muted">
                        Actualizado hace 1 min
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h6>Conductividad</h6>

                    <h2>80%</h2>

                    <small class="text-muted">
                        Actualizado hace 1 min
                    </small>

                </div>

            </div>

        </div>

    </div>




</div>



<style>




    .tank {
        position: relative;
        width: 185px;
        height: 185px;
        margin: 20px auto;
    }

    .tank-mask {
        position: absolute;
        inset: 0;
        z-index: 1;
        -webkit-mask-image: url('/images/copitank22-mask.png');
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-size: 92% 92%;
        -webkit-mask-position: center;
        mask-image: url('/images/copitank22-mask.png');
        mask-repeat: no-repeat;
        mask-size: 92% 92%;
        mask-position: center;
    }

    .water {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: #4da3ff;
        transition: height .5s;
    }

    .fill-body {
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        background: #4da3ff;
        z-index: 1;
        transition: height .5s ease;
        -webkit-mask-image: url('/images/copitank22-mask.png');
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-position: center;
        -webkit-mask-size: 100% 100%;
        mask-image: url('/images/copitank22-mask.png');
        mask-repeat: no-repeat;
        mask-position: center;
        mask-size: 100% 100%;
    }

    .tank img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
        pointer-events: none;
    }

    .line {
        position: absolute;
        left: 0;
        width: 115%;
        border-top: 1px dashed #000;
        font-size: 12px;
        font-weight: bold;
        text-align: right;
        z-index: 3;
        transform: translateX(16px);
    }

    .linea-20 {
        top: 76%;
    }

    .linea-40 {
        top: 58%;
    }

    .linea-60 {
        top: 40%;
    }

    .linea-80 {
        top: 24%;
    }

    .linea-100 {
        top: 10%;
    }

    .card {
        border: none;
    }
</style>
