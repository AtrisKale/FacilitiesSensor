@model FacilitiesSensor.Models.DashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "SCADA Tanque";
}

<div class="container mt-4">

    <!-- 🔵 TANQUE -->
    <div class="tank">
        <div class="tank-mask">
            <div class="fill-body" id="fill"></div>
        </div>

        <img src="/images/copitank22.png" alt="tanque overlay" />
    </div>

    <!-- 🚨 PANEL DE ALARMAS -->
    <div class="alarm-panel">
        <h3>Alarmas</h3>
        <ul id="listaAlarmas"></ul>
    </div>

</div>

<style>

    /* =======================
       TANQUE
    ======================= */

    .tank {
        position: relative;
        width: 185px;
        height: 185px;
        margin: 20px auto;
    }

    .tank-mask {
        position: absolute;
        inset: 0;
        z-index: 1;
    }

    .fill-body {
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 0%;
        background: #4da3ff;
        transition: height .5s ease;

        -webkit-mask-image: url('/images/copitank22-mask.png');
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-size: 100% 100%;
        -webkit-mask-position: center;

        mask-image: url('/images/copitank22-mask.png');
        mask-repeat: no-repeat;
        mask-size: 100% 100%;
        mask-position: center;
    }

    .tank img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
        pointer-events: none;
    }

    /* =======================
       ALARMAS
    ======================= */

    .alarm-panel {
        position: absolute;
        right: 20px;
        top: 20px;
        width: 260px;
        background: #111;
        color: white;
        padding: 10px;
        border-radius: 6px;
        font-family: monospace;
    }

    .alarm-panel h3 {
        margin-top: 0;
    }

    .alarm-panel ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .alarm-panel li {
        margin: 5px 0;
        padding: 5px;
        border-left: 4px solid red;
        background: #1a1a1a;
        font-size: 13px;
    }

</style>

<script>

    /* =======================
       ESTADO GLOBAL
    ======================= */

    let estadoAlarma = null;

    /* =======================
       OBJETO ALARMAS
    ======================= */

    const Alarmas = {
        VACIO: { texto: "Tanque vacío", color: "red" },
        BAJO: { texto: "Escasez de agua", color: "orange" },
        MITAD: { texto: "Mitad de tanque", color: "yellow" },
        LLENO: { texto: "Tanque lleno", color: "green" },
        DESBORDE: { texto: "⚠ Alerta por desborde", color: "red" }
    };

    /* =======================
       ACTUALIZAR SISTEMA
    ======================= */

    function actualizarSistema(nivel) {
        actualizarTanque(nivel);
        evaluarAlarmas(nivel);
    }

    /* =======================
       TANQUE
    ======================= */

    function actualizarTanque(nivel) {
        document.getElementById("fill").style.height = nivel + "%";
    }

    /* =======================
       ALARMAS
    ======================= */

    function evaluarAlarmas(nivel) {

        let nueva = null;

        if (nivel <= 0) nueva = Alarmas.VACIO;
        else if (nivel <= 20) nueva = Alarmas.BAJO;
        else if (nivel >= 45 && nivel <= 55) nueva = Alarmas.MITAD;
        else if (nivel >= 95 && nivel <= 100) nueva = Alarmas.LLENO;
        else if (nivel > 100) nueva = Alarmas.DESBORDE;

        if (nueva && (!estadoAlarma || estadoAlarma.texto !== nueva.texto)) {
            estadoAlarma = nueva;
            agregarAlarma(nueva, nivel);
        }
    }

    /* =======================
       MOSTRAR ALARMA
    ======================= */

    function agregarAlarma(alarma, nivel) {

        const lista = document.getElementById("listaAlarmas");

        const li = document.createElement("li");

        li.textContent = `[${new Date().toLocaleTimeString()}] ${alarma.texto} (${nivel}%)`;
        li.style.borderLeftColor = alarma.color;

        lista.prepend(li);
    }

    /* =======================
       SIMULACIÓN (PRUEBA)
    ======================= */

    setInterval(() => {

        let nivel = Math.floor(Math.random() * 120);

        actualizarSistema(nivel);

    }, 3000);

</script>