<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Toyoda Gosei") - TGPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            /* Sidebar */
            .sidebar {
                width: 220px;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background-color: #2c3e50;
                transition: all 0.3s ease;
            }

                .sidebar .logo {
                    width: 120px;
                }

            .sidebar-link {
                display: block;
                width: 100%;
                padding: 12px 0;
                text-align: center;
                color: #ffffff;
                text-decoration: none;
                font-weight: 500;
                transition: background-color 0.3s, color 0.3s;
            }

                .sidebar-link:hover {
                    background-color: #1e3a6b;
                    color: #00aaff;
                }

            .content-area {
                margin-left: 220px; /* espacio del sidebar */
                padding: 20px;
                display: flex;
                justify-content: center; /* centra horizontal */
                align-items: flex-start; /* alinea arriba */
                min-height: 100vh; /* ocupa toda la altura */
            }

    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar text-white p-0">
        <div class="d-flex flex-column align-items-center pt-3">
            <img src="~/images/tgrmxi.png" alt="Toyoda Gosei" class="logo mb-3">
                <a asp-controller="Home" asp-action="Login" class="sidebar-link">Cerrar sesión</a>
            </div>
        </div>

        <!-- Contenido principal -->
        <div class="content-area">
            @RenderBody()
        </div>
    </body>

</html>
